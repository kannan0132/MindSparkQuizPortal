# Environment Variables Configuration
# Copy this file to .env and fill in your actual values

# ===== SERVER CONFIGURATION =====
PORT=3000

# ===== DATABASE =====
# For local development
MONGODB_URI=mongodb://localhost:27017/mindspark-quiz

# For production (MongoDB Atlas)
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/mindspark-quiz?retryWrites=true&w=majority

# ===== AUTHENTICATION =====
# Generate a secure random string for JWT secret
# You can use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this

# Admin secret key for admin authentication
ADMIN_SECRET_KEY=your-admin-secret-key-change-this

# ===== CLIENT CONFIGURATION =====
# For local development
CLIENT_URL=http://localhost:5173

# For production (after deploying to Vercel)
# CLIENT_URL=https://your-app.vercel.app
